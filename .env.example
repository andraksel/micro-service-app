GATEWAY_URL=http://localhost:8080
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Service defaults used by Docker Compose
CACHE_TTL_SECONDS=60
HTTP_TIMEOUT_SECONDS=2
PAYMENT_TIMEOUT_SLEEP_SECONDS=3.5

# RabbitMQ Management UI
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Host ports. Override these if your machine already uses a port.
GATEWAY_PORT=8080
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
REDIS_PORT=6379
USER_SERVICE_PORT=8001
PRODUCT_SERVICE_PORT=8002
ORDER_SERVICE_PORT=8003
PAYMENT_SERVICE_PORT=8004
NOTIFICATION_SERVICE_PORT=8005
